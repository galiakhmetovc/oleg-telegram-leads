# PUR Leads greenfield defaults

PUR_DATABASE_PATH=./data/pur-leads.sqlite3
PUR_LOG_LEVEL=INFO
PUR_WEB_HOST=0.0.0.0
PUR_WEB_PORT=8000
PUR_BOOTSTRAP_ADMIN_USERNAME=admin
# Optional fixed bootstrap password. If empty, the app generates one and writes it to PUR_BOOTSTRAP_ADMIN_PASSWORD_FILE.
PUR_BOOTSTRAP_ADMIN_PASSWORD=
PUR_BOOTSTRAP_ADMIN_PASSWORD_FILE=./data/bootstrap-admin-password.txt
PUR_ZAI_API_KEY=
# Optional legacy name; PUR_ZAI_API_KEY has priority when both are set.
ZAI_API_KEY=
PUR_CATALOG_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
PUR_CATALOG_LLM_MODEL=glm-5.1
